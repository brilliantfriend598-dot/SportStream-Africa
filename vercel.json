{
  "framework": null,
  "buildCommand": "npx expo export -p web",
  "outputDirectory": "dist",
  "installCommand": "npm install --legacy-peer-deps",
  "functions": {
    "api/index.js": {
      "runtime": "nodejs20.x"
    }
  },
  "rewrites": [
    {
      "source": "/health",
      "destination": "/api/index.js"
    },
    {
      "source": "/fixtures/:path*",
      "destination": "/api/index.js"
    },
    {
      "source": "/standings/:path*",
      "destination": "/api/index.js"
    }
  ]
}
